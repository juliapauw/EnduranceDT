    properties (Access = private)
    RunTimer          % timer object for simulation
    SimData           % for data
    CurrentRow = 1    % row 
    AlertActive = false % sensitivity
    end
    
    methods (Access = private)
function updateSimulatie(app)
    if app.CurrentRow <= height(app.SimData)
        
        % current glucose
        C_glucose = app.SimData.glucose_level(app.CurrentRow);
        
        % show command window
        fprintf('Row %d: Glucose is %.0f\n', app.CurrentRow, C_glucose);

        % check with threshold 70 mg/dl (changeable) for 10 rows
        if app.CurrentRow > 10
            last_15_rows = app.SimData.glucose_level(app.CurrentRow-9 : app.CurrentRow);
     
            if mean(last_15_rows) < 100 && ~app.AlertActive
                app.WatchPanel.Visible = 'on';
                app.AlertActive = true;        
                beep;
                stop(app.RunTimer);            % Pause it
            end
        end
        
        app.CurrentRow = app.CurrentRow + 1;
    else
        stop(app.RunTimer);
    end
end
    end

    % Callbacks that handle component events
