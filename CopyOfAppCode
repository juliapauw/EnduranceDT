        % Button pushed function: DataGenerateInsightsButton
        function DataGenerateInsightsButtonPushed(app, event)
            % 1. load data
data = readtable('.csv');
app.TabGroup.SelectedTab = app.PostExercise;

%% post excercise
% 1. Left axis
yyaxis(app.UIAxes_PR, 'left');
plot(app.UIAxes_PR, data.distance, data.glucose_level, 'b-', 'LineWidth', 2);
xlabel(app.UIAxes_PR, 'Distance (km)');
ylabel(app.UIAxes_PR, 'Glucose Level (mg/dL)');

% 2. right axis
yyaxis(app.UIAxes_PR, 'right');
plot(app.UIAxes_PR, data.distance, data.pace, 'r', 'LineWidth',2);
xlabel(app.UIAxes_PR, 'Distance (km)');
ylabel(app.UIAxes_PR, 'Pace (min/km)');
set(app.UIAxes_PR, 'YDir', 'reverse');

% 3. determine the trend
glucose_trend = data.trend_glucose_level;
C_pace = data.pace(end);

if C_pace < 5.81 & glucose_trend < -0.5
    
else
    app.AdviceColor.Color = [0 0.6 0]; % green
    app.ActionBox.Value = 'Between distance 0.8 and 1.3 km you had a steady pace. Took first fuel after this phase en recovered glucose and increased pace in -0,04 min/km';
end

%% past comparison
% 1. Left axis
yyaxis(app.UIAxes_COM, 'left');
plot(app.UIAxes_COM, data.distance, data.pace, 'b', 'LineWidth', 2);
xlabel(app.UIAxes_COM, 'Distance (km)');
ylabel(app.UIAxes_COM, 'Pace (min/km)');
set(app.UIAxes_COM, 'YDir', 'reverse');

% 2. Right axis
yyaxis(app.UIAxes_COM, 'right');
plot(app.UIAxes_COM, data.distance, data.P_pace, 'r', 'LineWidth',2);
xlabel(app.UIAxes_COM, 'Distance (km)');
ylabel(app.UIAxes_COM, 'Pace (min/km)');
set(app.UIAxes_COM, 'YDir', 'reverse');

%% future Prediction
% 1. stimulation of prediction line
predicted_line = data.glucose_level + (data.future_trend_glucose_level * 2); % 2 min in future

plot(app.UIAxes_PRED, data.distance, data.glucose_level, 'b', 'LineWidth', 1.5);
hold(app.UIAxes_PRED, 'on');
plot(app.UIAxes_PRED, data.distance, predicted_line, 'r-', 'LineWidth', 1.5);
hold(app.UIAxes_PRED, 'off');

title(app.UIAxes_PRED, 'Glucose Prediction');
legend(app.UIAxes_PRED, 'Current', 'Predicted (Digital Twin)', 'Location', 'southwest');
ylabel(app.UIAxes_PRED, 'Glucose (mg/dL)');
xlabel(app.UIAxes_PRED, 'Distance (km)');

C_glucose = data.glucose_level(end);
TOTAL_SESSION_TIME=data.time_min(end);
rest_time = max(0, TOTAL_SESSION_TIME - data.time_min(end));
prediction_value = C_glucose + (data.future_trend_glucose_level(end) * rest_time);

% 2. advice 
glucose_threshold_low = 100;
if prediction_value < glucose_threshold_low
    app.PREDLabel.Text = 'DEOPTIMAL'; 
    app.PREDLabel.FontColor = [1 0.4 0]; %orange
    
    % calculate shortage
    shortage = glucose_threshold_low - prediction_value;
    
    app.AdviceTextArea.Value = sprintf(['DT Simulation: If you keep your goal pace in the next activity, ' ...
        'the predicted final value will be %.0f mg/dL. This is to low.' ...
        'Advice: Take %.0f gram extra carbs with you and divide this over the intensive pieces to avoid a dip.'], ...
        prediction_value, shortage);
else
    app.PREDLabel.Text = 'OPTIMAAL';
    app.PREDLabel.FontColor = [0.2 0.8 0.2]; %green
    
    app.AdviceTextArea.Value = sprintf(['DT Simulation: With an acceleration in the next activity' ...
        'the glucose level expected to remain stable (expected final level: %.0f mg/dL).' ...
        'Advice: Do not change your fuel strategy.'], ...
        prediction_value);
end

        end

        % Button pushed function: LiveExerciseButton
        function LiveExerciseButtonPushed(app, event)

    app.TabGroup.SelectedTab = app.LiveExercise;

    % 1. load data
    app.SimData = readtable('.csv');
    
    % 2. reset 
    app.CurrentRow = 1;
    app.AlertActive = false;
    app.WatchPanel.Visible = 'off'; 

    % 3. start timer
    app.RunTimer = timer('ExecutionMode', 'fixedRate', ...
                         'Period', 0.1, ... 
                         'TimerFcn', @(~,~) app.updateSimulatie());
    start(app.RunTimer);

        end

        % Button pushed function: DoneButton
        function DoneButtonPushed(app, event)

    app.WatchPanel.Visible = 'off'; % not visible
    app.AlertActive = false; % reset
    start(app.RunTimer); % start 
        end

        % Button pushed function: CloseButton
        function CloseButtonPushed(app, event)

    app.WatchPanel.Visible = 'off'; % not visible
    start(app.RunTimer); % start
    app.CurrentRow = app.CurrentRow + 120; % skip for 2 minutes
    app.AlertActive = false; % reset
        end
    end

